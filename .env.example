# Your Torn API key (get it from https://www.torn.com/preferences.php#tab=api)
# Recommended: Full Access key for maximum data
TORN_API_KEY=your_api_key_here

# Optional: additional API keys for faster faction sweeps (round-robin)
TORN_API_KEY_2=
TORN_API_KEY_3=

# Optional: TornStats API key (for CPR and war stat data)
TORNSTATS_API_KEY=

# Port (set automatically by Railway, leave empty for local stdio mode)
# PORT=3001
